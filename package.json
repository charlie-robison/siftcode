{
  "name": "siftcode",
  "version": "0.1.0",
  "description": "Sift through AI code changes. Review every line.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.siftcode.app",
    "productName": "siftcode",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "dmg": {
      "title": "siftcode",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.8.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charlie-robison/siftcode.git"
  },
  "author": "charlie-robison",
  "license": "MIT",
  "homepage": "https://github.com/charlie-robison/siftcode#readme"
}
